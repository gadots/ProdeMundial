# Supabase — get from https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# football-data.org — register free at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=<your-api-key>

# Random secret for cron job auth — generate with: openssl rand -hex 32
CRON_SECRET=<random-secret>
