# ──────────────────────────────────────────────
# Supabase (required for auth and database)
# ──────────────────────────────────────────────

# Supabase project URL (e.g. https://xyzabc.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — NEVER expose to the browser
# Used by sync-matches and admin endpoints
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────
# Match data (football-data.org)
# ──────────────────────────────────────────────

# Free tier: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# ──────────────────────────────────────────────
# Automated sync (GitHub Actions → /api/admin/sync)
# ──────────────────────────────────────────────

# Shared secret between GitHub Actions and Vercel.
# Must match on both sides. Generate with: openssl rand -hex 32
# Also set this as a GitHub Actions secret named CRON_SECRET.
CRON_SECRET=

# ──────────────────────────────────────────────
# Admin panel (/admin)
# ──────────────────────────────────────────────

# Admin login username (defaults to "admin" if not set)
ADMIN_USERNAME=admin

# Admin login password — REQUIRED to enable the admin panel.
# If not set, all /admin routes return 401.
ADMIN_PASSWORD=

# ──────────────────────────────────────────────
# E2E tests (Playwright)
# Copy to .env.local — playwright.config.ts reads .env.local
# ──────────────────────────────────────────────

# Email and password of a real Supabase account for E2E tests
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
