# ──────────────────────────────────────────────
# Supabase (requerido para producción)
# ──────────────────────────────────────────────

# URL del proyecto Supabase (ej: https://xyzabc.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública anon (segura para el browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave service_role — NUNCA exponerla al browser
# Usada por sync-matches y endpoints de admin
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────
# API de partidos (football-data.org)
# ──────────────────────────────────────────────

# Free tier: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# ──────────────────────────────────────────────
# Cron job (GitHub Actions → /api/admin/sync)
# ──────────────────────────────────────────────

# Secret compartido entre GitHub Actions secret y Vercel env var.
# Debe coincidir en ambos lados. Generalo con: openssl rand -hex 32
CRON_SECRET=

# ──────────────────────────────────────────────
# Tests E2E con Playwright
# Copiar a .env.local (no a .env — playwright.config.ts lee .env.local)
# ──────────────────────────────────────────────

# Email y contraseña de una cuenta real en Supabase para los tests
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
